# Importar las funciones necesarias de PySpark
from pyspark.sql.functions import col, year, count, round

print("Iniciando el cálculo de la Tasa de Incidencias (Consigna 5.4)...")

# 1. Leer las tablas de la capa Silver (usando el catálogo estándar)
df_envios = spark.read.table("silver_envios")
df_transportistas = spark.read.table("silver_transportistas")
df_incidencias = spark.read.table("silver_incidencias")

# 2. Unir envíos con transportistas para obtener la 'zona' y extraer el 'anio'
df_envios_zona = (df_envios
    .join(df_transportistas, on="id_transportista", how="inner")
    .withColumn("anio", year(col("fecha_envio")))
)

# 3. Calcular el total de envíos agrupados por zona y año
df_total_envios = (df_envios_zona
    .groupBy("zona", "anio")
    .agg(count("id_envio").alias("total_envios"))
)

# 4. Calcular el total de incidencias agrupadas por zona y año
df_incidencias_zona = (df_incidencias
    .join(df_envios_zona, on="id_envio", how="inner")
    .groupBy("zona", "anio")
    .agg(count("id_incidencia").alias("total_incidencias"))
)

# 5. Unir los totales y calcular la Tasa de Incidencias (%)
df_tasa = (df_total_envios
    .join(df_incidencias_zona, on=["zona", "anio"], how="left")
    .fillna({"total_incidencias": 0}) # Llenar con 0 donde no hubo incidencias
    .withColumn("tasa_incidencias_pct", round((col("total_incidencias") / col("total_envios")) * 100, 2))
)

# 6. Guardar el resultado como una nueva tabla en el Lakehouse
df_tasa.write.format("delta").mode("overwrite").saveAsTable("tasa_incidencias_zona")

print("¡Cálculo finalizado! La tabla 'tasa_incidencias_zona' se ha guardado correctamente.")

# Mostrar una vista previa de los datos
display(df_tasa)